---
import { siteConfig } from '../data/site';

interface Props {
  postCount: number;
  tagCount: number;
}

const { postCount, tagCount } = Astro.props;
---

<section class="hero section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">从一个稳妥的底子开始</p>
      <h1>{siteConfig.title}</h1>
      <p class="lead">{siteConfig.description}</p>

      <div class="hero-actions">
        <a class="button" href="/blog/">进入归档</a>
        <a class="button-secondary" href="/about/">查看方案</a>
      </div>
    </div>

    <aside class="hero-side">
      <div class="hero-side-copy">
        <p class="eyebrow eyebrow-soft">为长期写作预留空间</p>
        <h2>{siteConfig.tagline}</h2>
        <p>
          先把写作、发布、归档这三件事做好，之后再慢慢加上搜索、评论、
          表单或者边缘能力，也不用推倒重来。
        </p>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">{postCount}</span>
          <span class="stat-label">示例文章</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">{tagCount}</span>
          <span class="stat-label">主题标签</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">0</span>
          <span class="stat-label">多余插件</span>
        </div>
      </div>
    </aside>
  </div>
</section>
