---
import { formatDate } from '../utils/blog';

interface Props {
  publishDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { publishDate, updatedDate, tags = [] } = Astro.props;
---

<div class="post-meta">
  <div class="meta-row">
    <span>{formatDate(publishDate)}</span>
    {updatedDate && <span>Updated {formatDate(updatedDate)}</span>}
  </div>

  {
    tags.length > 0 && (
      <ul class="tag-list" aria-label="标签">
        {tags.map((tag) => <li><span class="pill">{tag}</span></li>)}
      </ul>
    )
  }
</div>
