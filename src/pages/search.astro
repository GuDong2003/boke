---
import { getCollection } from 'astro:content';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, sortPosts } from '../utils/blog';

const posts = sortPosts(await getCollection('blog'));
const totalPosts = posts.length;
---

<BaseLayout title="搜索" description="按标题、摘要和标签快速检索站内文章。">
  <SiteHeader />

  <main>
    <section class="section page-intro">
      <div class="container page-panel">
        <p class="eyebrow">搜索</p>
        <h1>从标题、摘要和标签里快速找到文章。</h1>
        <p class="lead">
          现在先用一套内置的轻量搜索，小站已经够用；等文章多起来，再切到
          Pagefind 也很方便。
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container search-shell">
        <label class="search-label" for="search-input">搜索文章</label>
        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="试试：写作、部署、架构"
          autocomplete="off"
          data-search-input
        />
        <p class="search-summary" data-search-summary>
          共 {totalPosts} 篇文章，可按标题、摘要和标签搜索。
        </p>

        <div class="search-results">
          {
            posts.map((post) => (
              <article
                class="search-card"
                data-search-entry
                data-title={post.data.title.toLowerCase()}
                data-description={post.data.description.toLowerCase()}
                data-tags={post.data.tags.join(' ').toLowerCase()}
              >
                <a class="search-card-link" href={`/blog/${post.slug}/`}>
                  <div class="search-card-head">
                    <p class="search-kicker">文章</p>
                    <h2>{post.data.title}</h2>
                  </div>

                  <p class="search-card-description">{post.data.description}</p>

                  <div class="search-card-meta">
                    <span>{formatDate(post.data.publishDate)}</span>
                    {post.data.tags.length > 0 && <span>{post.data.tags.join(' · ')}</span>}
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script define:vars={{ totalPosts }} is:inline>
    const input = document.querySelector('[data-search-input]');
    const summary = document.querySelector('[data-search-summary]');
    const entries = Array.from(document.querySelectorAll('[data-search-entry]'));

    if (input instanceof HTMLInputElement && summary instanceof HTMLElement) {
      const params = new URLSearchParams(window.location.search);
      const initialQuery = params.get('q');

      if (initialQuery) {
        input.value = initialQuery;
      }

      const updateSummary = (visible, query) => {
        if (!query) {
          summary.textContent = `共 ${totalPosts} 篇文章，可按标题、摘要和标签搜索。`;
          return;
        }

        if (visible > 0) {
          summary.textContent = `找到 ${visible} 篇和“${query}”相关的文章。`;
          return;
        }

        summary.textContent = `没有找到和“${query}”相关的文章。`;
      };

      const syncQuery = (query) => {
        const url = new URL(window.location.href);

        if (query) {
          url.searchParams.set('q', query);
        } else {
          url.searchParams.delete('q');
        }

        window.history.replaceState({}, '', url);
      };

      const update = () => {
        const query = input.value.trim().toLowerCase();
        let visible = 0;

        for (const entry of entries) {
          if (!(entry instanceof HTMLElement)) {
            continue;
          }

          const haystack = [
            entry.dataset.title ?? '',
            entry.dataset.description ?? '',
            entry.dataset.tags ?? '',
          ]
            .join(' ')
            .trim();

          const matched = !query || haystack.includes(query);
          entry.hidden = !matched;

          if (matched) {
            visible += 1;
          }
        }

        updateSummary(visible, input.value.trim());
        syncQuery(input.value.trim());
      };

      update();
      input.addEventListener('input', update);
    }
  </script>
</BaseLayout>
