---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面不存在" description="这个页面可能已经被移动，或者地址写错了。">
  <SiteHeader />

  <main>
    <section class="section page-intro">
      <div class="container page-panel">
        <p class="eyebrow">404</p>
        <h1>这个页面没有找到。</h1>
        <p class="lead">
          可能是链接过期了，也可能是地址输错了。你可以先回首页，或者直接去归档里找。
        </p>

        <div class="hero-actions not-found-actions">
          <a class="button" href="/">回到首页</a>
          <a class="button-secondary" href="/blog/">打开归档</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
