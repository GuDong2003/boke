---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const stack = [
  'Astro 负责静态页面和组件化布局。',
  'Markdown content collections 管理文章内容。',
  'GitHub 保存源码、文章和版本历史。',
  'Cloudflare Pages 负责部署、预览和 CDN 分发。',
];

const roadmap = [
  '如果你想开放讨论，可以把 giscus 评论打开。',
  '如果文章变多，可以把当前轻量搜索换成 Pagefind。',
  '如果以后真有需求，再用 Cloudflare Workers 接表单或自动化。',
];
---

<BaseLayout title="关于" description="这套博客方案为什么适合先发布、再扩展。">
  <SiteHeader />

  <main>
    <section class="section page-intro">
      <div class="container about-grid">
        <article class="page-panel">
          <p class="eyebrow">关于这个站</p>
          <h1>先把写作和发布跑通，再慢慢加需要的功能。</h1>
          <p class="lead">
            这套起步方案适合个人博客：前期足够简单，几个月内都不用维护复杂系统；
            以后想加搜索、评论、表单、边缘逻辑，也不需要重做。
          </p>
        </article>

        <aside class="panel">
          <p class="eyebrow">当前技术栈</p>
          <ul class="stack-list">
            {stack.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container split-grid">
        <article class="panel">
          <p class="eyebrow">写作方式</p>
          <h2>内容、代码、发布流程都放在同一个仓库里。</h2>
          <p>
            文章直接写在 Markdown 里，本地预览后通过 Git 提交，再交给 Cloudflare Pages
            构建和发布。流程很透明，也很好备份。
          </p>
        </article>

        <article class="panel">
          <p class="eyebrow">扩展路线</p>
          <h2>等归档真的长起来了，再加复杂功能。</h2>
          <ul class="detail-list">
            {roadmap.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
